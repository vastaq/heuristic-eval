.DS_Store
.env
.venv/
.conda/
node_modules/
__pycache__/
*.pyc

# Data stays local/private by default. Keep directory placeholders only.
eval_datasets/canonical/*
!eval_datasets/canonical/.gitkeep
eval_datasets/exports/*
!eval_datasets/exports/.gitkeep
eval_datasets/results/*
!eval_datasets/results/.gitkeep
eval_datasets/seeds/*
!eval_datasets/seeds/.gitkeep
eval_datasets/experiments/*
!eval_datasets/experiments/.gitkeep
eval_datasets/replay/outputs/*
!eval_datasets/replay/outputs/.gitkeep
eval_datasets/evolution/events.jsonl
eval_datasets/evolution/failure_patterns/*
!eval_datasets/evolution/failure_patterns/.gitkeep
